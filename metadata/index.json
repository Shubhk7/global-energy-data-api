      "category": "primary",
      "group": "energy",
      "path": "api/v1/primary/energy/energy_by_source.csv",
      "source": "OWID",
      "meta": {
        "description": "Breakdown of energy consumption by source over time",
        "columns": {
          "country": "Country name",
          "year": "Year",
          "coal": "Energy from coal (TWh)",
          "gas": "Energy from natural gas (TWh)",
          "oil": "Energy from oil (TWh)",
          "renewables": "Renewable energy (TWh)"
        },
        "units": "TWh",
        "time_range": {
          "start": 1965,
          "end": 2023
        },
        "update_frequency": "yearly"
      },
      "visualization": {
        "default_chart": "stacked_area",
        "x_axis": "year",
        "y_axis": "energy",
        "stacked": true
